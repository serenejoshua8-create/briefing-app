# Server
PORT=3000
# A long random string of your choosing. Required as the `x-app-secret` header
# on every mutating request once you deploy publicly. Generate one with:
# node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
APP_SHARED_SECRET=

# Anthropic (Claude) — console.anthropic.com
ANTHROPIC_API_KEY=

# Gemini — aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter — openrouter.ai/keys (used for instant PDF-upload analysis;
# free-tier models available, separate quota pool from the Gemini key above)
OPENROUTER_API_KEY=

# Supabase — Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Google Drive (read-only archive) — service account, not OAuth.
# Create a service account in Google Cloud Console, enable the Drive API,
# download its JSON key, and paste the ENTIRE JSON as a single line here.
# Then share your Daily Notes Drive folder with the service account's
# client_email (Viewer access is enough — this app only reads from Drive).
# NOTE: a service account has NO Drive storage quota of its own, so it can
# never create files in a personal (non-Shared-Drive) folder, no matter what
# permission it's given. Real Drive writes need the OAuth client below instead.
GOOGLE_SERVICE_ACCOUNT_KEY=
# The Drive folder ID containing your Daily Notes docs (from the folder's URL)
GOOGLE_DRIVE_FOLDER_ID=

# Google OAuth (Drive writes) — needed only for the instant-PDF-analysis
# Drive doc upload. Create an OAuth client in Google Cloud Console
# (APIs & Services → Credentials → Create Credentials → OAuth client ID →
# Web application), add ${your backend URL}/api/auth/google/callback as an
# authorized redirect URI, then paste its Client ID/Secret below. After
# deploying, visit GET /api/auth/google once in a browser (signed into the
# Google account that owns the Drive folder) to grant access — this exchanges
# a refresh token that's stored in Supabase (oauth_tokens table) and reused
# indefinitely after that.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-app.onrender.com/api/auth/google/callback

# CORS — the origin your frontend is served from
FRONTEND_ORIGIN=http://localhost:5500

# Server
PORT=3000
# A long random string of your choosing. Required as the `x-app-secret` header
# on every mutating request once you deploy publicly. Generate one with:
# node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
APP_SHARED_SECRET=

# Anthropic (Claude) — console.anthropic.com
ANTHROPIC_API_KEY=

# Gemini — aistudio.google.com/apikey
GEMINI_API_KEY=

# Supabase — Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Google OAuth (Drive access) — Google Cloud Console → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Use http://localhost:3000/oauth/callback while running scripts/get-refresh-token.js locally.
# Switch to your Render URL + /oauth/callback only if you re-run the flow in production.
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback
# Filled in after running: npm run get-refresh-token
GOOGLE_REFRESH_TOKEN=
# The Drive folder ID containing your Daily Notes docs (from the folder's URL)
GOOGLE_DRIVE_FOLDER_ID=

# CORS — the origin your frontend is served from
FRONTEND_ORIGIN=http://localhost:5500
